# API Configuration (base template)
# Copy/adjust this for .env.development / .env.production as needed

NEXT_PUBLIC_API_BASE_URL=/web/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Backend API URL (for Server Components / Route Handlers)
BACKEND_API_URL=http://localhost:8000

# Default User ID (must match a user in the database)
# Used for server-side API requests (X-User-ID header)
DEFAULT_USER_ID=69fad3df-d73f-45e1-9fb4-df52bd4857b0

# Robot Scope
# URL returning { robots: string[] } to restrict operator's robot access
# Leave empty to allow all robots (permissive default)
# NEXT_PUBLIC_ROBOT_SCOPE_URL=http://localhost:28080/v1/robot
